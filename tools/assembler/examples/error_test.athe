; AthenISA assembler syntax error catalog.
;
; The assembler currently aborts on the first error. Keep all cases commented
; and uncomment only one line at a time to check the diagnostic you want.
;
; Tip: uncomment only the instruction part. The text after the second ';'
; can stay as the expected diagnostic note.

; Unknown or unsupported instructions
; FOO R1, R2                         ; expected: unknown instruction
; LDI R1, 0x1234                     ; expected: unknown instruction, pseudo-instructions not implemented yet

; Wrong operand count
; NOP R1                             ; expected: expected 1 tokens, got 2
; RET R0                             ; expected: expected 1 tokens, got 2
; MOV R1                             ; expected: expected 3 tokens, got 2
; ADD R1, R2                         ; expected: expected 4 tokens, got 3
; ADD R1, R2, R3, R4                 ; expected: expected 4 tokens, got 5
; STORE 0[R1]                        ; expected: expected 3 tokens, got 2
; JMP                                ; expected: expected 2 tokens, got 1
; BEQ loop, extra                    ; expected: expected 2 tokens, got 3

; Invalid registers
; MOV R8, R0                         ; expected: invalid register
; ADD R1, RA, R2                     ; expected: invalid register
; STORE 0[R1], R9                    ; expected: invalid register

; Invalid immediates and symbols
; LI R1, hello                       ; expected: undefined symbol
; LI R1, 0xGG                        ; expected: invalid number
; LI R1, 0b102                       ; expected: invalid number
; SRA R1, R2, x                      ; expected: undefined symbol
; JMP missing_label                  ; expected: undefined symbol
; BNE missing_label                  ; expected: undefined symbol

; Invalid symbol definitions
; 1bad:                              ; expected: invalid symbol name
; bad-name:                          ; expected: invalid symbol name
; bad$name:                          ; expected: invalid symbol name
; : 0x10                             ; expected: symbol name cannot be empty
; bad_const: 0xGG                    ; expected: invalid number
; bad_const: 1 2                     ; expected: symbol value must contain exactly one value
; loop: ADDI R1, 1                   ; expected: symbol value must contain exactly one value
; dup:                               ; expected: duplicate symbol, uncomment this line and the next line together
; dup:                               ; expected: duplicate symbol, uncomment this line and the previous line together

; Invalid memory operand syntax
; LOAD R1, R2                        ; expected: memory operand must end with ']'
; LOAD R1, 0[R2                      ; expected: memory operand must end with ']'
; LOAD R1, 0[]                       ; expected: missing base register
; LOAD R1, []                        ; expected: missing base register
; LOAD R1, 0[R2]x                    ; expected: memory operand must end with ']'
; LOAD R1, 0 [R2]                    ; expected: wrong token count, spaces inside off5[rb] are not supported

; Invalid memory offsets and symbols
; STORE nope[R1], R2                 ; expected: undefined symbol
