; AthenISA assembler warning catalog.
;
; These lines are intentionally valid, but they should produce warnings because
; some values do not fit in their encoded field and are truncated.

big_imm: 0x123
far_addr: 0xFFFF
far_branch_target: 5000

LI R1, big_imm       ; warning: imm8 truncates 0x123 to 0x23
LI R2, -1            ; warning: imm8 truncates -1 to 0xFF
LIH R3, 0x1FF        ; warning: imm8 truncates 0x1FF to 0xFF
SLL R4, R5, 16       ; warning: imm4 truncates 16 to 0x0
LOAD R6, 16[R7]      ; warning: off5 truncates 16 to 0x10
STORE -17[R6], R7    ; warning: off5 truncates -17 to 0xF
JMP far_addr         ; warning: addr11 truncates 0xFFFF to 0x7FF
BEQ far_branch_target ; warning: off11 truncates target-derived offset
